generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  //moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"

}

enum Role {
    ADOPTER
    ADMIN

}


model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  name      String
  password  String
  role      Role     @default(ADOPTER)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users") 
}

